classDiagram

class Owner {
    +String name
    +int available_time
    +List pets
    +add_pet(pet)
    +remove_pet(pet)
    +view_schedule()
}

class Pet {
    +String name
    +String species
    +int age
    +List tasks
    +add_task(task)
    +remove_task(task)
    +get_tasks()
}

class Task {
    +String name
    +int duration
    +int priority
    +String category
    +String time
    +bool completed
    +String frequency
    +date due_date
    +mark_complete()
    +update_priority(priority)
    +get_details()
}

class Scheduler {
    +List daily_plan
    +generate_schedule(owner)
    +sort_tasks(tasks)
    +filter_tasks(tasks, available_time)
    +detect_conflicts(tasks)
    +sort_by_time(tasks)
    +filter_by_status(tasks, completed)
    +filter_by_pet(owner, pet_name)
    +mark_task_complete(task, pet)
}

Owner "1" --> "*" Pet : owns
Pet "1" --> "*" Task : manages
Scheduler ..> Owner : reads pet data
Scheduler ..> Task : sorts and schedules
Scheduler ..> Pet : adds recurring tasks